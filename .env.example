# Python Agent System Environment Variables

# OpenAI API Configuration
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# BigQuery Configuration
BIGQUERY_DATASET=analytics
BIGQUERY_LOCATION=US

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/agent_system
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration (for agent memory)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_CORS_ORIGINS=["http://localhost:3000"]

# Authentication
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/agent_system.log

# Agent Configuration
AGENT_DEFAULT_MODEL=gpt-4-turbo-preview
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
AGENT_MEMORY_TTL=86400

# Data Processing
PANDAS_MAX_ROWS=1000000
DUCKDB_MEMORY_LIMIT=4GB
PIPELINE_CONCURRENCY=4

# Feature Flags
ENABLE_ASYNC_AGENTS=true
ENABLE_MULTI_AGENT_CHAT=true
ENABLE_TOOL_CALLING=true
ENABLE_HUMAN_IN_LOOP=false

# External Services
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
WEBHOOK_TIMEOUT=30

# Development
DEBUG=false
TESTING=false